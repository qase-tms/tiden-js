{
  "name": "@tiden/browser",
  "version": "0.1.0",
  "description": "Tiden error-tracking browser SDK. Emits the envelope wire format to a Tiden ingest endpoint, with no third-party error-SDK dependency.",
  "keywords": ["tiden", "error-tracking", "browser", "sdk"],
  "homepage": "https://github.com/qase-tms/tiden-js/tree/main/browser",
  "bugs": "https://github.com/qase-tms/tiden-js/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qase-tms/tiden-js.git",
    "directory": "browser"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "stacktrace-parser": "^0.1.11"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
